# Public URL this backend is reachable at (OAuth redirects, QStash callbacks)
BACKEND_PUBLIC_URL=http://localhost:8080

# Frontend origin for CORS and flight-link generation
FRONTEND_URL=

# Random secret for signing cookies (CSRF state tokens)
AUTH_SECRET=

# Twitch Developer App — used for streamer OAuth flows (channel:bot authorization)
TWITCH_APP_CLIENT_ID=
TWITCH_APP_CLIENT_SECRET=

# Comma-separated Twitch user IDs that get admin permissions
ADMIN_TWITCH_IDS=

# Bot Client ID — the Twitch application that issued the bot tokens.
# If the bot uses the same app as above, leave this empty (falls back to TWITCH_APP_CLIENT_ID).
# If the bot uses a separate (public) Twitch app without a client secret, set this to that app's Client ID.
TWITCH_BOT_CLIENT_ID=

# Bot account tokens — access and refresh tokens for the bot Twitch user.
# When TWITCH_BOT_CLIENT_ID differs from TWITCH_APP_CLIENT_ID the refresh is done
# without a client secret (public-client flow per Twitch OAuth docs).
TWITCH_BOT_ACCESS_TOKEN=
TWITCH_BOT_REFRESH_TOKEN=

# Twitch user ID of the bot owner (gets broadcaster-level perms in commands)
TWITCH_BOT_OWNER_ID=

# Shared secret for admin API + QStash webhook auth
INTERNAL_JOB_SECRET=

# Secret for SimLink flight data ingest endpoint
SIMLINK_INGEST_SECRET=

# Upstash Redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Upstash QStash — delayed job scheduling
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=
